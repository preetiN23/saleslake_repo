                      "expression": "SUM(`avg_days_to_pay`)"
                    },
                    {
                      "name": "payment_status",
                      "expression": "`payment_status`"
                    },
                    {
                      "name": "sum(total_billed)",
                      "expression": "SUM(`total_billed`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "showTitle": true,
                "title": "Invoice Payment Status Overview"
