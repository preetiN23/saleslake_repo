{
  "datasets": [
    {
      "name": "ds_exec_kpi",
      "displayName": "Executive KPI Summary",
      "queryLines": [
        "SELECT * FROM saleslake_dev.gold_dev.vw_exec_kpi_summary"
      ]
    },
    {
      "name": "ds_sales_monthly",
      "displayName": "Sales Monthly Trend",
      "queryLines": [
        "SELECT year_month, net_revenue, profit, margin_pct, orders FROM saleslake_dev.gold_dev.vw_sales_monthly ORDER BY year_month"
      ]
    },
    {
      "name": "ds_top10_products",
      "displayName": "Top 10 Products",
      "queryLines": [
        "SELECT product_name, category, net_revenue, profit, units_sold FROM saleslake_dev.gold_dev.vw_top10_products ORDER BY net_revenue DESC"
      ]
    },
    {
      "name": "ds_category_perf",
      "displayName": "Category Performance",
      "queryLines": [
        "SELECT category, net_revenue, profit, margin_pct, units_sold FROM saleslake_dev.gold_dev.vw_category_performance ORDER BY net_revenue DESC"
      ]
    },
    {
      "name": "ds_regional",
      "displayName": "Regional Performance",
      "queryLines": [
        "SELECT region_name, country, net_revenue, profit, margin_pct,        orders, unique_customers, active_stores FROM saleslake_dev.gold_dev.vw_regional_performance ORDER BY net_revenue DESC"
      ]
    },
    {
      "name": "ds_store_perf",
      "displayName": "Store Performance",
      "queryLines": [
        "SELECT store_name, store_type, city, state,        net_revenue, profit, orders, revenue_per_sqft FROM saleslake_dev.gold_dev.vw_store_performance ORDER BY net_revenue DESC LIMIT 25"
      ]
    },
    {
      "name": "ds_segment",
      "displayName": "Customer Segment Performance",
      "queryLines": [
        "SELECT segment, customers, orders, net_revenue, profit, revenue_per_customer FROM saleslake_dev.gold_dev.vw_customer_segment_perf ORDER BY net_revenue DESC"
      ]
    },
    {
      "name": "ds_discount",
      "displayName": "Discount Effectiveness",
      "queryLines": [
        "SELECT discount_code, discount_type, orders_with_discount,        net_revenue, profit, margin_pct, discount_pct_of_gross FROM saleslake_dev.gold_dev.vw_discount_effectiveness ORDER BY net_revenue DESC"
      ]
    },
    {
      "name": "ds_channel",
      "displayName": "Channel Performance",
      "queryLines": [
        "SELECT channel, orders, units, net_revenue, profit, margin_pct FROM saleslake_dev.gold_dev.vw_channel_perf ORDER BY net_revenue DESC"
      ]
    },
    {
      "name": "ds_payment",
      "displayName": "Payment Method Mix",
      "queryLines": [
        "SELECT payment_method, orders, net_revenue, avg_order_value FROM saleslake_dev.gold_dev.vw_payment_method_perf ORDER BY net_revenue DESC"
      ]
    },
    {
      "name": "ds_invoice_status",
      "displayName": "Invoice Status Summary",
      "queryLines": [
        "SELECT payment_status, invoice_count, total_billed, avg_days_to_pay FROM saleslake_dev.gold_dev.vw_invoice_status_summary"
      ]
    },
    {
      "name": "ds_yoy",
      "displayName": "YoY Growth",
      "queryLines": [
        "SELECT year, month_name, net_revenue_current, net_revenue_prior_year, yoy_growth_pct FROM saleslake_dev.gold_dev.vw_sales_yoy WHERE yoy_growth_pct IS NOT NULL ORDER BY year DESC, month DESC"
      ]
    }
  ],
