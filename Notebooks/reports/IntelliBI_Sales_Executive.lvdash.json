              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "payment_status",
                  "scale": {
                    "type": "categorical"
                  }
                },
                "y": {
                  "fieldName": "sum(total_billed)",
                  "scale": {
                    "type": "quantitative"
                  }
                },
                "label": {
                  "show": true
                },
                "extra": [
                  {
                    "fieldName": "sum(invoice_count)"
                  },
                  {
                    "fieldName": "sum(avg_days_to_pay)"
